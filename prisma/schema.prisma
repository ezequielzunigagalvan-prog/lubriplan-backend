generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

model AppSettings {
  id Int @id @default(1)

  // =========================
  // Ejecución / Evidencias
  // =========================
  executionEvidenceRequired Boolean @default(false)

  // =========================
  // Inventario
  // =========================
  preventNegativeStock Boolean @default(true)
  lowStockWarningEnabled Boolean @default(true)

  // =========================
  // Alertas / IA
  // =========================
  technicianOverloadEnabled Boolean @default(true)
  predictiveAlertsEnabled   Boolean @default(true)
  aiSummaryEnabled          Boolean @default(true)
  criticalActivityEmailEnabled Boolean @default(true)
  conditionReportEmailEnabled  Boolean @default(true)
  overdueSummaryEmailEnabled   Boolean @default(true)
  monthlyReportEmailEnabled    Boolean @default(true)

  // =========================  
  // Sobrecarga técnicos
  // =========================
  overloadWindowDays Int @default(7)
  overloadOverdueLookbackDays Int @default(30)
  overloadCapacityPerDay Int @default(6)
  overloadWarnRatio Float @default(1.1)
  overloadCriticalRatio Float @default(1.4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(TECHNICIAN)
  active       Boolean  @default(true)

  technicianId Int?        @unique
  technician   Technician? @relation("UserTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  notifications    Notification[]
  conditionReports ConditionReport[]
  dismissedConditionReports ConditionReport[] @relation("ConditionReportDismissedBy")
  requestedPurchaseOrders PurchaseOrder[] @relation("PORequester")
  approvedPurchaseOrders  PurchaseOrder[] @relation("POApprover")
  auditLogs    AuditLog[]

  userPlants UserPlant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Technician {
  id        Int       @id @default(autoincrement())

  plantId   Int
  plant     Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)

  name      String
  code      String
  specialty String
  status    String    @default("Activo")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  executions Execution[]
  routes     Route[]

  user User? @relation("UserTechnician")

  @@index([plantId])
  @@unique([plantId, code]) // recomendado: código único por planta
}

model EquipmentArea {
  id          Int      @id @default(autoincrement())
  plantId     Int
  plant       Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  createdAt   DateTime @default(now())

  equipments Equipment[]

  @@unique([plantId, name])
  @@index([plantId])
  @@index([name])
}

model Equipment {
  id Int @id @default(autoincrement())

  plantId Int
  plant   Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  code        String? @unique
  name        String
  location    String
  status      String
  description String?

  areaId Int?
  area   EquipmentArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)

  criticality String?

  conditionReports ConditionReport[]
  oilSamples       OilSample[]
  assetMappings    AssetMapping[]
  lubricationCard  LubricationCard?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  routes     Route[]
  executions Execution[]

  @@index([plantId])
  @@index([areaId])
  @@index([status])
}

model Lubricant {
  id        Int     @id @default(autoincrement())

  plantId Int
  plant   Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  name      String
  unit      String  @default("ml")
  stock     Float   @default(0)
  minStock  Float?
  brand     String?
  type      String?
  viscosity String?
  location  String?
  notes     String?

  code     String?
  supplier String?
  unitCost Float?

  // Ficha técnica
  isoVg            String?
  nlgiGrade        String?
  baseType         String?   // MINERAL | SINTETICO | SEMISINT
  operatingTempMin Float?
  operatingTempMax Float?
  sdsUrl           String?
  sdsPublicId      String?
  compatibility    String?   // texto libre o JSON con IDs compatibles

  routes Route[] @relation("LubricantRoutes")
  movements LubricantMovement[]
  oilSamples OilSample[]
  purchaseOrderItems PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plantId])
}

model LubricantMovement {
  id Int @id @default(autoincrement())

  lubricantId Int
  lubricant   Lubricant @relation(fields: [lubricantId], references: [id], onDelete: Cascade)

  executionId Int?
  execution   Execution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  type     String
  quantity Float
  reason   String?
  note     String?

  // ✅ NUEVO
  inputQuantity     Float?
  inputUnit         String?
  convertedQuantity Float?
  convertedUnit     String?

  stockBefore Float?
  stockAfter  Float?

  createdAt DateTime @default(now())

  @@index([lubricantId, createdAt])
  @@index([executionId])
}

model Route {
  id            Int     @id @default(autoincrement())

  plantId Int
  plant   Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  name           String
  normalizedName String
  routeKind      String  @default("LUBRICATION")
  lubricantType  String?
  lubricantName  String?

  quantity Float?
  unit     String? @default("ml")

  pumpStrokeValue Float?
  pumpStrokeUnit  String?

  frequencyDays Int

  frequencyType String?
  weeklyDays    Int[]     @default([])
  monthlyAnchorDay Int?
  customIntervalDays Int?

  method       String?
  points       Int?
  instructions String?

  isEmergency Boolean @default(false)

  lastDate DateTime?
  nextDate DateTime?

  imageUrl String?
  imagePublicId String?

  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  lubricantId Int?
  lubricant   Lubricant? @relation("LubricantRoutes", fields: [lubricantId], references: [id], onDelete: SetNull)

  technicianId Int?
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  executions Execution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([plantId])
  @@index([equipmentId])
  @@index([lubricantId])
  @@index([technicianId])

  @@index([plantId, equipmentId, normalizedName])
}

model Execution {
  id Int @id @default(autoincrement())

  plantId Int
  plant   Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  origin ExecutionOrigin @default(ROUTE)

  routeId Int?
  route   Route? @relation(fields: [routeId], references: [id], onDelete: Cascade)

  equipmentId Int?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  manualTitle        String?
  manualInstructions String?

  correctiveReports ConditionReport[] @relation("CorrectiveExecution")

  technicianId Int?
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  lubricantMovements LubricantMovement[]

  status      String    @default("PENDING")
  scheduledAt DateTime  @default(now())
  executedAt  DateTime?

  usedQuantity Float?
  condition    String?
  observations String?

  // ✅ NUEVO
  usedInputQuantity      Float?
  usedInputUnit          String?
  usedConvertedQuantity  Float?
  usedConvertedUnit      String?

  evidenceImage String?
  evidenceImagePublicId String?
  evidenceNote  String?

  inventoryDeductedAt DateTime?

  // Clave de idempotencia para operaciones offline. El cliente genera un UUID v4 y lo envía en el body.
  clientId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([plantId])
  @@index([routeId])
  @@index([equipmentId])
  @@index([technicianId])
  @@index([status, scheduledAt])
  @@index([origin, scheduledAt])
}

enum ExecutionOrigin {
  ROUTE
  ONE_OFF
  MANUAL
  // Si quieres separar emergentes:
  // EMERGENCY
}

enum ConditionLevel {
  BUENO
  REGULAR
  MALO
  CRITICO
}

enum ConditionReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum ConditionReportCategory {
  FUGA
  RUIDO
  VIBRACION
  TEMPERATURA
  CONTAMINACION
  OTRO
}

enum ScheduledJobType {
  MONTHLY_EXEC_REPORT
  OVERDUE_SUMMARY
}

enum PurchaseOrderStatus {
  DRAFT
  REQUESTED
  APPROVED
  RECEIVED
  CANCELLED
}

enum OilSampleStatus {
  PENDING
  NORMAL
  CAUTION
  CRITICAL
}

enum WebhookEvent {
  EXECUTION_COMPLETED
  CONDITION_REPORT_CREATED
  LUBRICANT_LOW_STOCK
  OIL_SAMPLE_ALERT
  PURCHASE_ORDER_APPROVED
  PURCHASE_ORDER_RECEIVED
}

model ConditionReport {
  id           Int @id @default(autoincrement())

  plantId Int
  plant   Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  equipmentId  Int
  reportedById Int

  condition     ConditionLevel
  category      ConditionReportCategory?
  description   String
  detectedAt    DateTime                 @db.Date
  evidenceImage String?
  evidenceImagePublicId String?

  status ConditionReportStatus @default(OPEN)

  correctiveExecutionId Int?
  correctiveExecution   Execution? @relation("CorrectiveExecution", fields: [correctiveExecutionId], references: [id], onDelete: SetNull)
  correctiveNotes       String?
  correctiveScheduledAt DateTime?

  createdAt DateTime @default(now())

  equipment  Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  reportedBy User      @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  resolvedAt  DateTime?
  dismissedAt DateTime?
  dismissedById Int?
  dismissedBy   User? @relation("ConditionReportDismissedBy", fields: [dismissedById], references: [id], onDelete: SetNull)

  @@index([plantId])
  @@index([equipmentId])
  @@index([detectedAt])
  @@index([status])
  @@index([plantId, status])
  @@map("condition_reports")
}

enum NotificationType {
  CONDITION_REPORTED
  CONDITION_RESOLVED 
  CONDITION_DISMISSED
  EMERGENCY_CREATED
  EXEC_ASSIGNED
  EXEC_CONDITION_CRITICAL
  EXEC_OVERDUE
  LOW_STOCK
}

model Notification {
  id        Int              @id @default(autoincrement())

  plantId Int?
  plant   Plant? @relation(fields: [plantId], references: [id], onDelete: SetNull)

  userId    Int
  type      NotificationType
  title     String
  message   String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plantId])
  @@index([userId, readAt])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model Plant {
  id       Int     @id @default(autoincrement())
  name     String
  timezone String  @default("America/Mexico_City")
  active   Boolean @default(true)

  monthlyReportEnabled        Boolean @default(true)
  monthlyReportDay            Int     @default(1)
  monthlyReportHour           Int     @default(8)
  monthlyReportRecipientsExtra String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relaciones
  userPlants UserPlant[]

  equipmentAreas EquipmentArea[]
  equipments     Equipment[]
  lubricants     Lubricant[]
  routes         Route[]
  executions     Execution[]
  conditionReports ConditionReport[]
  notifications  Notification[]
  technicians Technician[]
  scheduledJobRuns ScheduledJobRun[]
  purchaseOrders   PurchaseOrder[]
  oilSamples       OilSample[]
  webhookEndpoints    WebhookEndpoint[]
  auditLogs           AuditLog[]
  integrationConfigs  IntegrationConfig[]
}

model UserPlant {
  id        Int      @id @default(autoincrement())
  userId    Int
  plantId   Int
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([userId, plantId])
  @@index([plantId])
}

// =========================
// ÓRDENES DE COMPRA
// =========================
model PurchaseOrder {
  id      Int                 @id @default(autoincrement())
  plantId Int
  plant   Plant               @relation(fields: [plantId], references: [id], onDelete: Cascade)

  status  PurchaseOrderStatus @default(DRAFT)
  notes   String?

  requestedById Int
  requestedBy   User  @relation("PORequester", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedById  Int?
  approvedBy    User? @relation("POApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  approvedAt   DateTime?
  receivedAt   DateTime?
  expectedDate DateTime?

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plantId])
  @@index([status])
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  lubricantId  Int
  lubricant    Lubricant @relation(fields: [lubricantId], references: [id], onDelete: Cascade)

  requestedQty Float
  receivedQty  Float?
  unit         String
  unitCost     Float?
  notes        String?

  @@index([purchaseOrderId])
  @@index([lubricantId])
}

// =========================
// ANÁLISIS DE ACEITE
// =========================
model OilSample {
  id        Int      @id @default(autoincrement())
  plantId   Int
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  lubricantId Int?
  lubricant   Lubricant? @relation(fields: [lubricantId], references: [id], onDelete: SetNull)

  sampledAt    DateTime
  labReference String?
  labReportUrl String?

  // Propiedades físico-químicas
  viscosity40  Float?   // cSt a 40°C
  viscosity100 Float?   // cSt a 100°C
  tan          Float?   // Total Acid Number mg KOH/g
  tbn          Float?   // Total Base Number mg KOH/g
  waterPct     Float?   // % agua
  flashPoint   Float?   // °C punto de inflamación

  // Metales de desgaste (ppm)
  ironPpm     Float?
  copperPpm   Float?
  aluminumPpm Float?
  leadPpm     Float?
  chromiumPpm Float?
  siliconPpm  Float?

  // Contaminación
  particleCount  Int?     // ISO 4406
  particleIso    String?  // e.g. "18/16/13"

  status OilSampleStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plantId])
  @@index([equipmentId])
  @@index([sampledAt])
}

// =========================
// AUDIT LOG
// =========================
model AuditLog {
  id        Int      @id @default(autoincrement())
  plantId   Int?
  userId    Int?
  userEmail String?

  action   String   // CREATE | UPDATE | DELETE
  model    String   // Route | Equipment | Lubricant | Technician | ...
  recordId String?
  changes  Json?    // { before: {}, after: {} }

  ip        String?
  createdAt DateTime @default(now())

  plant Plant? @relation(fields: [plantId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([plantId])
  @@index([model])
  @@index([userId])
  @@index([createdAt])
}

// =========================
// WEBHOOKS
// =========================
model WebhookEndpoint {
  id      Int     @id @default(autoincrement())
  plantId Int
  plant   Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  url    String
  secret String
  events WebhookEvent[]
  active Boolean        @default(true)
  description String?

  deliveries WebhookDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plantId])
}

model WebhookDelivery {
  id         Int             @id @default(autoincrement())
  endpointId Int
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  event          String
  payload        Json
  status         String   @default("PENDING") // PENDING | SUCCESS | FAILED
  attempts       Int      @default(0)
  lastAttemptAt  DateTime?
  responseStatus Int?
  responseBody   String?

  createdAt DateTime @default(now())

  @@index([endpointId, status])
  @@index([status, createdAt])
}

model ScheduledJobRun {
  id        Int              @id @default(autoincrement())
  jobType   ScheduledJobType
  plantId   Int
  period    String           // YYYY-MM
  status    String           @default("PENDING") // PENDING | SENT | FAILED | SKIPPED

  recipientsJson String?
  subject        String?
  errorMessage   String?

  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([jobType, plantId, period])
  @@index([plantId, period])
  @@index([jobType, status])
}

// =========================
// CARTA DE LUBRICACIÓN
// =========================
enum LubricationFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum LubricationMethod {
  MANUAL
  AUTO
  GREASE_GUN
  OIL_CAN
}

model LubricationCard {
  id          Int       @id @default(autoincrement())
  equipmentId Int       @unique
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  imageUrl      String?
  imagePublicId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  points LubricationPoint[]

  @@index([equipmentId])
}

model LubricationPoint {
  id     Int             @id @default(autoincrement())
  cardId Int
  card   LubricationCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  label     String
  x         Float
  y         Float

  lubricant String?
  quantity  Float?
  unit      String?              @default("ml")
  frequency LubricationFrequency @default(MONTHLY)
  method    LubricationMethod    @default(MANUAL)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cardId])
}

// =========================
// CMMS INTEGRATIONS
// =========================
enum IntegrationType {
  MAXIMO
  SAP_ODATA
  SAP_RFC
  CSV
}

model IntegrationConfig {
  id      Int             @id @default(autoincrement())
  plantId Int
  plant   Plant           @relation(fields: [plantId], references: [id], onDelete: Cascade)

  type        IntegrationType
  name        String
  baseUrl     String?
  apiKey      String?
  username    String?
  passwordEnc String?
  extra       Json?
  active      Boolean @default(true)

  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assetMappings   AssetMapping[]
  syncLogs        IntegrationSyncLog[]

  @@index([plantId])
  @@index([type])
}

model AssetMapping {
  id              Int               @id @default(autoincrement())
  integrationId   Int
  integration     IntegrationConfig @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  equipmentId     Int?
  equipment       Equipment?        @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  externalId      String
  externalName    String?
  externalData    Json?
  confirmed       Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([integrationId, externalId])
  @@index([integrationId])
  @@index([equipmentId])
}

model IntegrationSyncLog {
  id            Int               @id @default(autoincrement())
  integrationId Int
  integration   IntegrationConfig @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  direction     String   // PULL | PUSH
  entity        String   // assets | workorders
  status        String   // OK | PARTIAL | ERROR
  recordsTotal  Int      @default(0)
  recordsOk     Int      @default(0)
  recordsError  Int      @default(0)
  errors        Json?

  startedAt     DateTime @default(now())
  finishedAt    DateTime?

  @@index([integrationId])
  @@index([status])
  @@index([startedAt])
}

model LandingChatLog {
  id          Int      @id @default(autoincrement())
  sessionId   String   @unique
  messages    Json
  ip          String?
  isHotLead   Boolean  @default(false)
  hotKeywords String[]
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isHotLead])
  @@index([createdAt])
}
