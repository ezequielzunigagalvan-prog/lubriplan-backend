# ===============================
# SERVER
# ===============================
PORT=3001
NODE_ENV=development   # development | production

# ===============================
# DATABASE
# ===============================
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lubri_plan"

# ===============================
# AUTH
# ===============================
# IMPORTANT: En producción usa un valor aleatorio de 64+ bytes
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIA_ESTO_EN_PRODUCCION"
JWT_EXPIRES=8h

# ===============================
# AI CONFIG
# ===============================
# mock = no llama a OpenAI, usa respuesta generada localmente
# provider = llama a OpenAI (requiere OPENAI_API_KEY)
AI_MODE=mock

AI_SCHEMA_VERSION=1
AI_CACHE_TTL_HOURS=24
AI_RATE_LIMIT_USER_PER_HOUR=10
AI_RATE_LIMIT_PLANT_PER_HOUR=50
AI_LANG_DEFAULT=es-MX

# Requerido solo si AI_MODE=provider
OPENAI_API_KEY=
# Modelos válidos: gpt-4o-mini, gpt-4o, gpt-4.1-mini, gpt-4.1
OPENAI_MODEL=gpt-4o-mini

# ===============================
# EMAIL
# ===============================
MAIL_PROVIDER=resend

# API Key de Resend (https://resend.com)
RESEND_API_KEY=re_YOUR_API_KEY_HERE

EMAIL_FROM="LubriPlan <notifications@tudominio.com>"

# URL base del frontend (sin slash final)
APP_BASE_URL=http://localhost:5173

# ===============================
# ALERTAS (OPCIONAL)
# ===============================
# Hora local (0-23) a la que se envía el resumen de vencidos
OVERDUE_SUMMARY_HOUR=8

# ===============================
# CLOUDINARY (OPCIONAL - para subida de imágenes)
# ===============================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
